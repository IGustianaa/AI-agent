# ===========================================
# Telegram Bot Configuration
# ===========================================
# Dapatkan token dari @BotFather di Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ===========================================
# AI Provider: 'openai' atau 'groq'
# ===========================================
# Groq -> gratis & cepat (recommended untuk mulai)
# OpenAI -> kualitas premium, berbayar
AI_PROVIDER=groq

# ===========================================
# Groq (https://console.groq.com)
# ===========================================
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ===========================================
# OpenAI (https://platform.openai.com)
# ===========================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ===========================================
# AI Behavior
# ===========================================
SYSTEM_PROMPT=Kamu adalah AI assistant yang helpful, ramah, dan informatif. Jawab dalam bahasa yang sama dengan user.

# Maksimal pesan yang disimpan dalam history per user
MAX_HISTORY=20

# ===========================================
# Access Control (opsional)
# ===========================================
# Kosongkan agar semua user bisa pakai bot
# Isi dengan Telegram user ID dipisah koma, contoh: 123456789,987654321
# Cek user ID kamu dengan bot @userinfobot
ALLOWED_USERS=
