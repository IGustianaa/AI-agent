# ===========================================
# Telegram Bot Configuration
# ===========================================
# Dapatkan token dari @BotFather di Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ===========================================
# AI Provider: 'groq' | 'openai' | 'bedrock'
# ===========================================
# groq    -> gratis & cepat (recommended untuk mulai)
# openai  -> kualitas premium, berbayar
# bedrock -> Amazon Bedrock (Claude/Llama/Mistral via AWS), berbayar
AI_PROVIDER=groq

# ===========================================
# Groq (https://console.groq.com)
# ===========================================
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ===========================================
# OpenAI (https://platform.openai.com)
# ===========================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ===========================================
# Amazon Bedrock (https://console.aws.amazon.com/bedrock)
# ===========================================
# Region tempat model diaktifkan di Bedrock
AWS_REGION=us-east-1

# Credential AWS. Bisa juga dikosongkan kalau pakai IAM role di EC2,
# atau AWS_PROFILE dari ~/.aws/credentials.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Contoh model ID:
#   anthropic.claude-3-5-sonnet-20241022-v2:0
#   anthropic.claude-3-5-haiku-20241022-v1:0
#   anthropic.claude-3-haiku-20240307-v1:0
#   meta.llama3-1-70b-instruct-v1:0
#   mistral.mistral-large-2407-v1:0
# Beberapa model perlu inference profile prefix (us.*, eu.*), contoh:
#   us.anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# ===========================================
# AI Behavior
# ===========================================
SYSTEM_PROMPT=Kamu adalah AI assistant yang helpful, ramah, dan informatif. Jawab dalam bahasa yang sama dengan user. Gunakan tools bila diperlukan.

# Maksimal pesan terakhir yang diambil dari DB per user (turn history)
MAX_HISTORY=30

# Batas iterasi tool-call dalam 1 turn (proteksi loop)
MAX_TOOL_ITERATIONS=5

# ===========================================
# Persistent storage (SQLite)
# ===========================================
DB_PATH=data/bot.db

# ===========================================
# Streaming
# ===========================================
STREAM_EDIT_INTERVAL_MS=1200

# ===========================================
# Tools
# ===========================================
DEFAULT_TIMEZONE=Asia/Jakarta

# Tavily API key untuk web_search (opsional, https://tavily.com).
# Kalau kosong, fallback ke DuckDuckGo Instant Answer (hasil terbatas).
TAVILY_API_KEY=

# ===========================================
# Access Control (opsional)
# ===========================================
# Kosongkan agar semua user bisa pakai bot
# Isi dengan Telegram user ID dipisah koma, contoh: 123456789,987654321
# Cek user ID kamu dengan bot @userinfobot
ALLOWED_USERS=
