# ============================================================
# AI Mining Agent - Environment Configuration
# ============================================================

# --- AI Provider (untuk optimasi mining) ---
# Pilih: 'groq' (gratis & cepat) | 'openai'
AI_PROVIDER=groq

# --- Groq (Rekomendasi - Gratis) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- OpenAI (Opsional) ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# --- Mining Configuration ---
# Algoritma: randomx | cryptonight | argon2 | kawpow
MINING_ALGORITHM=randomx

# Pool URL (contoh untuk Monero)
POOL_URL=stratum+tcp://pool.supportxmr.com:3333

# Wallet address
WALLET_ADDRESS=your_wallet_address_here

# Worker name (identifier untuk rig kamu)
WORKER_NAME=ai-miner-01

# --- Resource Limits ---
# Persentase CPU yang boleh digunakan (1-100)
MAX_CPU_PERCENT=75

# Jumlah thread (0 = auto detect)
MINING_THREADS=0

# Suhu maksimal CPU sebelum throttle (Celsius)
MAX_CPU_TEMP=80

# --- AI Optimization ---
# Interval AI menganalisis performa (dalam detik)
AI_CHECK_INTERVAL=300

# Auto-optimize (AI otomatis adjust parameter)
AUTO_OPTIMIZE=true

# --- Monitoring ---
# Port untuk dashboard web (0 = disabled)
DASHBOARD_PORT=3000

# Log level: debug | info | warn | error
LOG_LEVEL=info

# --- Schedule (Opsional) ---
# Jadwal mining (format: HH:MM-HH:MM, kosong = 24/7)
# Contoh: hanya mining malam hari
MINING_SCHEDULE=22:00-06:00
